# Copy to .env and fill in. `src/config.py` loads this automatically (python-dotenv).
# Everything here has a working default except GOOGLE_API_KEY -- without it,
# LLM_PROVIDER falls back to "mock" (tests/eval only, refused for live HTTP traffic)
# and EMBEDDING_PROVIDER=gemini has nothing to authenticate with.

# Single key -- covers both the planning LLM (Gemini) and RAG embeddings
# (models/gemini-embedding-001). Get one at https://aistudio.google.com/apikey
GOOGLE_API_KEY=<YOUR_GOOGLE_API_KEY>

# "gemini" | "mock" -- "mock" only works for pytest (MockLLMClient); the API
# refuses to serve live requests in mock mode (see src/main.py::get_agent_llm).
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash

# "gemini" | "openai" | "local" -- "local" needs no key at all (sentence-transformers)
# but downloads a model on first run; "openai" needs OPENAI_API_KEY set separately.
EMBEDDING_PROVIDER=gemini
# OPENAI_API_KEY=

# Agent loop / cost controls
MAX_AGENT_STEPS=6
LLM_TIMEOUT_SECONDS=20

# API server
API_HOST=0.0.0.0
API_PORT=8000

# Optional: LangSmith hosted tracing (a visual trace UI at smith.langchain.com
# for every LLM call and graph step). Entirely opt-in -- leave unset and
# nothing changes; these are standard LangChain env vars, auto-detected by
# langchain-core, no code change needed. Each run's LangSmith trace is named
# after our own run_id (see src/agent/graph.py::run()), so it correlates with
# the same run_id in the API response and stdout logs.
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=<YOUR_LANGCHAIN_API_KEY>
LANGCHAIN_PROJECT=plotline-assignment
